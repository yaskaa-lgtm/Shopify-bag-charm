{{ 'sb-sections.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} {
    --sb-testi-bg: {{ section.settings.bg_color }};
    --sb-testi-fg: {{ section.settings.text_color }};
    --sb-testi-accent: {{ section.settings.accent_color }};
  }
</style>

<div class="sb-testi">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="sb-h2 sb-testi__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="sb-testi__grid">
      {%- for block in section.blocks -%}
        <figure class="sb-testi__card" {{ block.shopify_attributes }}>
          <div class="sb-testi__stars" aria-label="{{ block.settings.rating }} out of 5">
            {%- assign r = block.settings.rating | at_most: 5 -%}
            {%- for i in (1..5) -%}{% if i <= r %}★{% else %}☆{% endif %}{%- endfor -%}
          </div>
          <blockquote class="sb-testi__quote">{{ block.settings.quote }}</blockquote>
          {%- if block.settings.author != blank -%}
            <figcaption class="sb-testi__author">— {{ block.settings.author }}</figcaption>
          {%- endif -%}
        </figure>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "SB Testimonials",
  "tag": "section",
  "class": "sb-section sb-section--testi",
  "max_blocks": 9,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Besties Say"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Stars accent",
      "default": "#ff3d5a"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Absolutely love it — the quality is beautiful and it gives my look a fabulous extra touch."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Verified Bestie"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SB Testimonials",
      "blocks": [
        { "type": "review" },
        { "type": "review", "settings": { "quote": "I sell these in my store and my customers love the quality so much.", "author": "Verified Retailer" } },
        { "type": "review", "settings": { "quote": "The phone grip is amazing — pretty, practical and it never lets go. A daily essential.", "author": "Verified Bestie" } }
      ]
    }
  ]
}
{% endschema %}
