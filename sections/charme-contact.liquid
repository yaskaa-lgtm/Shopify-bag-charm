{%- comment -%} Charmé contact page with the real Shopify contact form. {%- endcomment -%}
<div class="page-head"><div class="wrap"><h1>Get in touch</h1><div class="updated">We answer our own email — usually within one business day.</div></div></div>

<div class="wrap"><div class="contact">
  <div>
    {%- form 'contact' -%}
      {%- if form.posted_successfully? -%}
        <div class="note"><b>Thanks!</b> Your message is on its way — we'll reply within one business day.</div>
      {%- endif -%}
      {%- if form.errors -%}
        <div class="note"><b>Hmm.</b> {{ form.errors | default_errors }}</div>
      {%- endif -%}
      <div class="form-field"><label for="n">Name</label><input id="n" type="text" name="contact[name]" placeholder="Your name" required></div>
      <div class="form-field"><label for="e">Email</label><input id="e" type="email" name="contact[email]" placeholder="you@email.com" required></div>
      <div class="form-field"><label for="o">Order number (optional)</label><input id="o" type="text" name="contact[order]" placeholder="#1234"></div>
      <div class="form-field"><label for="m">Message</label><textarea id="m" name="contact[body]" placeholder="How can we help?" required></textarea></div>
      <button class="cta" type="submit" style="width:100%;justify-content:center">Send message</button>
    {%- endform -%}
  </div>
  <div class="contact-info">
    <div class="kicker">Other ways to reach us</div>
    <div class="h2" style="font-size:clamp(24px,4vw,34px)">Real humans, fast replies.</div>
    <b>Email</b><p>{{ shop.email | default: 'hello@charme.com' }}</p>
    <b>Order help</b><p>Include your order number and we'll sort it quickly.</p>
    <b>Shipping &amp; returns</b><p>See <a href="/pages/shipping-returns" style="color:var(--persimmon);text-decoration:underline">Shipping &amp; Returns</a> and the <a href="/pages/refund-policy" style="color:var(--persimmon);text-decoration:underline">Refund Policy</a>.</p>
    <b>Response time</b><p>Usually within one business day, Monday–Friday.</p>
  </div>
</div></div>

{% schema %}
{ "name": "Charmé Contact", "settings": [] }
{% endschema %}
