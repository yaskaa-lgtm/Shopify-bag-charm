{%- comment -%} Charmé homepage body. Header/footer come from the layout. {%- endcomment -%}
{%- liquid
  assign prod_img = section.settings.product_image
  assign hero_img = section.settings.hero_image | default: prod_img
  assign look_img = section.settings.lookbook_image | default: prod_img
  assign shop_url = routes.all_products_collection_url
-%}

<!-- HERO -->
<section class="hero">
  <div class="wrap" style="padding:0">
    <div class="hero__grid">
      <div class="hero__copy">
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h1>Your bag,<br>but make it <em>you.</em></h1>
        <p class="sub">Elevated clip-on charms that refresh any bag in seconds — swap them, stack them, gift them.</p>
        <a href="{{ shop_url }}" class="cta">Shop the charm <span class="price">$24.99</span></a>
      </div>
      <div class="hero__vis">
        {%- if hero_img != blank -%}
          {{ hero_img | image_url: width: 1200 | image_tag: loading: 'eager', alt: hero_img.alt | default: 'Charmé bag charm', widths: '400,600,900,1200' }}
        {%- else -%}
          <div class="charm-badge"><svg viewBox="0 0 120 120"><use href="#charm"/></svg></div>
          <div class="slot-note">Image slot · hero-lifestyle 1080×1350</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<!-- TRUST -->
<div class="trust"><div class="wrap" style="padding:0"><div class="trust__grid">
  <div>Ships in <b>8–15 days</b>, tracked</div>
  <div><b>Real leather</b> — not plastic</div>
  <div>Arrives <b>gift-ready</b></div>
</div></div></div>

<!-- SHOP -->
<section class="block" id="shop">
  <div class="wrap">
    <div class="kicker">The one everyone's clipping on</div>
    <div class="h2">Meet the charm</div>
    <div class="bundles">
      <div class="card">
        <div class="card__top"><span class="tag">Bestseller</span>
          {%- if prod_img != blank -%}{{ prod_img | image_url: width: 700 | image_tag: loading: 'lazy', class: 'mini mini--photo', alt: 'Charmé bag charm', widths: '300,500,700' }}{%- else -%}<svg class="mini" viewBox="0 0 120 120"><use href="#charm"/></svg>{%- endif -%}
        </div>
        <div class="card__body"><h3>The Charm — Single</h3><span class="save">One clip. A whole new bag.</span><div class="price-row"><span class="now">$24.99</span><span class="was">$39</span></div><a href="{{ shop_url }}" class="buy">Add to bag</a></div>
      </div>
      <div class="card">
        <div class="card__top"><span class="tag" style="background:var(--gold);color:var(--ink)">Save $11</span>
          {%- if prod_img != blank -%}{{ prod_img | image_url: width: 700 | image_tag: loading: 'lazy', class: 'mini mini--photo', alt: 'Charmé bag charm two-pack', widths: '300,500,700' }}{%- else -%}<svg class="mini" viewBox="0 0 120 120"><use href="#charm"/></svg>{%- endif -%}
        </div>
        <div class="card__body"><h3>Mix &amp; Match — x2</h3><span class="save">Two moods, one strap</span><div class="price-row"><span class="now">$39</span><span class="was">$50</span></div><a href="{{ shop_url }}" class="buy">Add to bag</a></div>
      </div>
      <div class="card">
        <div class="card__top"><span class="tag" style="background:var(--persimmon)">Free ship</span>
          {%- if prod_img != blank -%}{{ prod_img | image_url: width: 700 | image_tag: loading: 'lazy', class: 'mini mini--photo', alt: 'Charmé bag charm gift set', widths: '300,500,700' }}{%- else -%}<svg class="mini" viewBox="0 0 120 120"><use href="#charm"/></svg>{%- endif -%}
        </div>
        <div class="card__body"><h3>Gift Set — x3</h3><span class="save">Sorted for three people (or you)</span><div class="price-row"><span class="now">$54</span><span class="was">$75</span></div><a href="{{ shop_url }}" class="buy">Add to bag</a></div>
      </div>
    </div>
    <div style="text-align:center;margin-top:30px"><a href="{{ shop_url }}" class="cta">See full details</a></div>
  </div>
</section>

<!-- HOW -->
<section class="block">
  <div class="wrap">
    <div class="kicker">How it works</div>
    <div class="h2">Three seconds, done</div>
    <div class="steps">
      <div class="step"><h4>Clip it on</h4><p>Universal lobster clasp fits totes, handbags, backpacks, and keys. No tools, no fuss.</p></div>
      <div class="step"><h4>Change your mood</h4><p>Light enough to swap daily, weighted enough to feel like it belongs on a real bag.</p></div>
      <div class="step"><h4>Show it off</h4><p>Built to photograph. The detail people ask about before they ask where you got it.</p></div>
    </div>
  </div>
</section>

<!-- COLORWAYS -->
<section class="block" id="colorways">
  <div class="wrap">
    <div class="kicker">Pick a mood · or three</div>
    <div class="h2">The colorways</div>
    <div class="ways">
      <div class="way"><div class="chip" style="background:var(--gold)"></div><span>Goldenhour</span></div>
      <div class="way"><div class="chip" style="background:var(--persimmon)"></div><span>Spritz</span></div>
      <div class="way"><div class="chip" style="background:var(--patina)"></div><span>Patina</span></div>
      <div class="way"><div class="chip" style="background:var(--ink)"></div><span>Noir</span></div>
      <div class="way"><div class="chip" style="background:var(--cream)"></div><span>Crème</span></div>
    </div>
  </div>
</section>

<!-- LOOKBOOK -->
<div class="look">
  <div class="wrap" style="padding:0">
    <div class="look__grid">
      <div class="look__vis">
        {%- if look_img != blank -%}
          {{ look_img | image_url: width: 1200 | image_tag: loading: 'lazy', alt: 'Charmé bag charm styled on a bag', widths: '400,600,900,1200' }}
        {%- else -%}
          <div class="charm-badge" style="box-shadow:10px 10px 0 var(--cream)"><svg viewBox="0 0 120 120"><use href="#charm"/></svg></div>
          <div class="slot-note">Image slot · lookbook 1080×1350</div>
        {%- endif -%}
      </div>
      <div class="look__copy">
        <div class="kicker" style="color:var(--gold-hi)">The lookbook</div>
        <div class="h2">Not a toy.<br>A statement.</div>
        <p class="quote">"A $300 bag shouldn't need replacing to feel new. One clip-on charm, endless moods."</p>
        <div class="attr">— Charmé, est. 2026</div>
      </div>
    </div>
  </div>
</div>

<!-- REVIEWS -->
<section class="block">
  <div class="wrap">
    <div class="kicker">What buyers say</div>
    <div class="h2">Verified &amp; obsessed</div>
    <div class="reviews">
      <div class="review"><div class="stars">★★★★★</div><p>"Way heavier and nicer than I expected — looks like it cost triple. Everyone at brunch asked."</p><div class="who">★ Verified buyer</div></div>
      <div class="review"><div class="stars">★★★★★</div><p>"Bought one, came back for the gift set. The little box makes it feel expensive."</p><div class="who">★ Verified buyer</div></div>
      <div class="review"><div class="stars">★★★★★</div><p>"Clips on solid, hasn't scratched my bag, and it actually photographs. Rare."</p><div class="who">★ Verified buyer</div></div>
    </div>
    <p style="font-size:12px;color:var(--muted);margin-top:16px">Sample reviews shown — replace with real Judge.me reviews before launch (FTC).</p>
  </div>
</section>

<!-- GIFT -->
<div class="gift" id="gift" style="background:var(--persimmon);color:var(--cream);text-align:center;border-bottom:2px solid var(--ink)">
  <div class="wrap" style="padding:0"><div class="inner">
    <div class="h2">The easy "just because."</div>
    <p>Under $30, arrives gift-ready in a clean little box, and she'll actually use it. Sorted for birthdays, stocking-stuffers, and secret santa.</p>
    <a href="{{ shop_url }}" class="cta" style="background:var(--cream);color:var(--ink);border-color:var(--cream)">Shop gift sets</a>
  </div></div>
</div>

{% schema %}
{
  "name": "Charmé Home",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Hero eyebrow", "default": "The it-girl bag charm · $24.99" },
    { "type": "image_picker", "id": "product_image", "label": "Product photo (used everywhere)", "info": "Upload once — fills the hero, all 3 cards, and the lookbook." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image override (optional)" },
    { "type": "image_picker", "id": "lookbook_image", "label": "Lookbook image override (optional)" }
  ],
  "presets": [ { "name": "Charmé Home" } ]
}
{% endschema %}
