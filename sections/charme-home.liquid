{%- comment -%}
  Charmé custom homepage.
  Self-contained: includes its own announcement bar, marquee, header nav and footer.
  Dawn's header-group / footer-group are suppressed on the index template in layout/theme.liquid.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;600;800;900&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&display=swap" rel="stylesheet">

<style>
  :root{
    --ink:#1C1B19;
    --cream:#F6F1E7;
    --persimmon:#E4572E;
    --patina:#4E7C82;
    --gold:#C9A227;
    --gold-hi:#E4C25A;
    --radius:14px;
    --radius-lg:26px;
    --maxw:1200px;
    --display:"Archivo",system-ui,sans-serif;
    --body:"DM Sans",system-ui,sans-serif;
  }
  .charme-page *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{background:var(--cream);color:var(--ink);font-family:var(--body);line-height:1.5;-webkit-font-smoothing:antialiased}
  .charme-page a{color:inherit;text-decoration:none}
  .charme-page img{display:block;max-width:100%}
  .charme-page .wrap{max-width:var(--maxw);margin:0 auto;padding:0 20px}
  .charme-page .display{font-family:var(--display);font-weight:900;letter-spacing:-.02em;line-height:.92;text-transform:uppercase}
  /* ---- Wordmark with clasp on É ---- */
  .charme-page .logo{font-family:var(--display);font-weight:900;text-transform:uppercase;letter-spacing:.01em;position:relative;display:inline-flex;align-items:flex-start;line-height:1}
  .charme-page .logo .e-wrap{position:relative;display:inline-block}
  .charme-page .logo .clasp{position:absolute;top:-0.46em;right:-0.30em;width:0.55em;height:0.72em;pointer-events:none}
  .charme-page .logo .acc{position:absolute;top:-0.14em;right:0.04em;width:0.34em;height:0.10em;background:var(--ink);transform:rotate(-18deg);border-radius:2px}
  /* ---- Announcement + marquee ---- */
  .charme-page .announce{background:var(--ink);color:var(--cream);text-align:center;font-size:12px;letter-spacing:.14em;text-transform:uppercase;padding:9px 12px;font-weight:600}
  .charme-page .marquee{background:var(--persimmon);color:var(--cream);overflow:hidden;white-space:nowrap;border-top:2px solid var(--ink);border-bottom:2px solid var(--ink)}
  .charme-page .marquee__track{display:inline-block;padding:10px 0;animation:charme-scroll 26s linear infinite;font-family:var(--display);font-weight:800;text-transform:uppercase;letter-spacing:.06em;font-size:14px}
  .charme-page .marquee__track span{margin:0 14px}
  .charme-page .marquee__track .dot{color:var(--gold-hi)}
  @keyframes charme-scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
  /* ---- Header ---- */
  .charme-page .site-head{position:sticky;top:0;z-index:50;background:var(--cream);border-bottom:2px solid var(--ink)}
  .charme-page .nav{display:flex;align-items:center;justify-content:space-between;height:64px}
  .charme-page .nav .logo{font-size:26px}
  .charme-page .nav__links{display:none;gap:26px;font-size:13px;letter-spacing:.1em;text-transform:uppercase;font-weight:700}
  .charme-page .nav__right{display:flex;align-items:center;gap:16px;font-size:13px;letter-spacing:.08em;text-transform:uppercase;font-weight:700}
  .charme-page .bag{border:2px solid var(--ink);border-radius:999px;padding:6px 14px;background:var(--gold);}
  @media(min-width:860px){.charme-page .nav__links{display:flex}}
  /* ---- Hero ---- */
  .charme-page .hero{border-bottom:2px solid var(--ink)}
  .charme-page .hero__grid{display:grid;grid-template-columns:1fr}
  @media(min-width:860px){.charme-page .hero__grid{grid-template-columns:1.05fr .95fr}}
  .charme-page .hero__copy{padding:44px 20px 48px}
  @media(min-width:860px){.charme-page .hero__copy{padding:70px 40px 70px}}
  .charme-page .eyebrow{font-family:var(--display);font-weight:800;text-transform:uppercase;letter-spacing:.14em;font-size:12px;color:var(--persimmon);margin-bottom:18px}
  .charme-page .hero h1{font-family:var(--display);font-weight:900;text-transform:uppercase;line-height:.9;letter-spacing:-.02em;font-size:clamp(44px,10vw,86px)}
  .charme-page .hero h1 em{font-style:italic;color:var(--persimmon)}
  .charme-page .hero p.sub{font-size:clamp(16px,2.4vw,19px);max-width:30ch;margin:22px 0 30px;color:#3a3733}
  .charme-page .cta{display:inline-flex;align-items:center;gap:10px;background:var(--ink);color:var(--cream);font-family:var(--display);font-weight:800;text-transform:uppercase;letter-spacing:.06em;font-size:15px;padding:16px 26px;border-radius:999px;border:2px solid var(--ink);transition:transform .15s ease, background .15s ease}
  .charme-page .cta:hover{transform:translateY(-2px);background:var(--persimmon);border-color:var(--persimmon)}
  .charme-page .cta .price{background:var(--gold);color:var(--ink);border-radius:999px;padding:3px 10px;font-size:13px}
  .charme-page .hero__vis{background:var(--patina);border-top:2px solid var(--ink);position:relative;min-height:340px;display:grid;place-items:center;overflow:hidden}
  @media(min-width:860px){.charme-page .hero__vis{border-top:none;border-left:2px solid var(--ink)}}
  .charme-page .slot-note{position:absolute;bottom:12px;left:12px;font-size:10px;letter-spacing:.1em;text-transform:uppercase;background:rgba(28,27,25,.75);color:var(--cream);padding:5px 9px;border-radius:6px;font-weight:700}
  /* ---- Charm illustration ---- */
  .charme-page .charm-badge{width:min(78%,320px);aspect-ratio:1;background:var(--cream);border:3px solid var(--ink);border-radius:50%;display:grid;place-items:center;box-shadow:10px 10px 0 var(--ink)}
  .charme-page .charm-badge svg{width:62%}
  /* ---- Trust bar ---- */
  .charme-page .trust{background:var(--ink);color:var(--cream)}
  .charme-page .trust__grid{display:grid;grid-template-columns:1fr;gap:0}
  @media(min-width:720px){.charme-page .trust__grid{grid-template-columns:repeat(3,1fr)}}
  .charme-page .trust__grid div{padding:18px 20px;text-align:center;font-size:13px;letter-spacing:.05em;text-transform:uppercase;font-weight:600;border-bottom:1px solid #ffffff22}
  @media(min-width:720px){.charme-page .trust__grid div{border-bottom:none;border-right:1px solid #ffffff22}.charme-page .trust__grid div:last-child{border-right:none}}
  .charme-page .trust b{color:var(--gold-hi)}
  /* ---- Section scaffolding ---- */
  .charme-page section.block{padding:64px 0;border-bottom:2px solid var(--ink)}
  .charme-page .kicker{font-family:var(--display);font-weight:800;text-transform:uppercase;letter-spacing:.14em;font-size:12px;color:var(--patina);margin-bottom:12px}
  .charme-page .h2{font-family:var(--display);font-weight:900;text-transform:uppercase;line-height:.95;letter-spacing:-.01em;font-size:clamp(30px,5.5vw,52px)}
  /* ---- Bundles ---- */
  .charme-page .bundles{display:grid;grid-template-columns:1fr;gap:18px;margin-top:34px}
  @media(min-width:800px){.charme-page .bundles{grid-template-columns:repeat(3,1fr)}}
  .charme-page .card{border:2px solid var(--ink);border-radius:var(--radius-lg);overflow:hidden;background:var(--cream);display:flex;flex-direction:column;transition:transform .15s ease}
  .charme-page .card:hover{transform:translateY(-4px)}
  .charme-page .card__top{aspect-ratio:4/3;display:grid;place-items:center;position:relative;border-bottom:2px solid var(--ink)}
  .charme-page .card:nth-child(1) .card__top{background:var(--gold)}
  .charme-page .card:nth-child(2) .card__top{background:var(--persimmon)}
  .charme-page .card:nth-child(3) .card__top{background:var(--patina)}
  .charme-page .card__top .mini{width:60%;filter:drop-shadow(6px 6px 0 rgba(28,27,25,.25))}
  .charme-page .tag{position:absolute;top:12px;left:12px;background:var(--ink);color:var(--cream);font-family:var(--display);font-weight:800;text-transform:uppercase;letter-spacing:.06em;font-size:11px;padding:5px 10px;border-radius:8px;transform:rotate(-4deg)}
  .charme-page .card__body{padding:18px 18px 22px;display:flex;flex-direction:column;gap:6px;flex:1}
  .charme-page .card__body h3{font-family:var(--display);font-weight:900;text-transform:uppercase;font-size:20px;letter-spacing:-.01em}
  .charme-page .card__body .save{font-size:12px;font-weight:700;color:var(--persimmon);text-transform:uppercase;letter-spacing:.06em}
  .charme-page .price-row{margin-top:auto;display:flex;align-items:baseline;gap:8px;padding-top:10px}
  .charme-page .price-row .now{font-family:var(--display);font-weight:900;font-size:24px}
  .charme-page .price-row .was{text-decoration:line-through;color:#8a857d;font-size:14px}
  .charme-page .buy{margin-top:12px;text-align:center;background:var(--ink);color:var(--cream);font-family:var(--display);font-weight:800;text-transform:uppercase;letter-spacing:.05em;font-size:13px;padding:12px;border-radius:999px;border:2px solid var(--ink);transition:background .15s}
  .charme-page .buy:hover{background:var(--persimmon);border-color:var(--persimmon)}
  /* ---- How it works ---- */
  .charme-page .steps{display:grid;grid-template-columns:1fr;gap:22px;margin-top:34px;counter-reset:s}
  @media(min-width:760px){.charme-page .steps{grid-template-columns:repeat(3,1fr)}}
  .charme-page .step{position:relative;padding-top:14px;border-top:3px solid var(--ink)}
  .charme-page .step::before{counter-increment:s;content:"0" counter(s);font-family:var(--display);font-weight:900;font-size:40px;display:block;line-height:1;color:var(--persimmon)}
  .charme-page .step h4{font-family:var(--display);font-weight:800;text-transform:uppercase;font-size:17px;margin:10px 0 6px}
  .charme-page .step p{font-size:15px;color:#3a3733}
  /* ---- Colorways ---- */
  .charme-page .ways{display:flex;flex-wrap:wrap;gap:14px;margin-top:30px}
  .charme-page .way{flex:1 1 130px;border:2px solid var(--ink);border-radius:var(--radius);overflow:hidden;text-align:center}
  .charme-page .way .chip{height:78px}
  .charme-page .way span{display:block;font-family:var(--display);font-weight:800;text-transform:uppercase;font-size:12px;letter-spacing:.06em;padding:9px 4px;border-top:2px solid var(--ink)}
  /* ---- Lookbook ---- */
  .charme-page .look{background:var(--ink);color:var(--cream);border-bottom:2px solid var(--ink)}
  .charme-page .look__grid{display:grid;grid-template-columns:1fr}
  @media(min-width:860px){.charme-page .look__grid{grid-template-columns:1fr 1fr}}
  .charme-page .look__vis{min-height:320px;background:var(--gold);position:relative;display:grid;place-items:center;border-bottom:2px solid var(--cream)}
  @media(min-width:860px){.charme-page .look__vis{border-bottom:none;border-right:2px solid var(--cream)}}
  .charme-page .look__copy{padding:54px 26px}
  @media(min-width:860px){.charme-page .look__copy{padding:72px 48px}}
  .charme-page .look__copy .h2{color:var(--cream)}
  .charme-page .look__copy .quote{font-family:var(--display);font-style:italic;font-weight:600;font-size:clamp(20px,3vw,28px);line-height:1.15;margin:18px 0 8px}
  .charme-page .look__copy .attr{font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold-hi);font-weight:700}
  /* ---- Reviews ---- */
  .charme-page .reviews{display:grid;grid-template-columns:1fr;gap:18px;margin-top:32px}
  @media(min-width:760px){.charme-page .reviews{grid-template-columns:repeat(3,1fr)}}
  .charme-page .review{border:2px solid var(--ink);border-radius:var(--radius);padding:22px;background:var(--cream)}
  .charme-page .stars{color:var(--gold);font-size:15px;letter-spacing:2px}
  .charme-page .review p{font-size:15px;margin:10px 0 14px}
  .charme-page .review .who{font-size:12px;letter-spacing:.08em;text-transform:uppercase;font-weight:700;color:#6a655d}
  /* ---- Gifting ---- */
  .charme-page .gift{background:var(--persimmon);color:var(--cream);text-align:center;border-bottom:2px solid var(--ink)}
  .charme-page .gift .inner{padding:56px 20px}
  .charme-page .gift .h2{color:var(--cream)}
  .charme-page .gift p{max-width:46ch;margin:14px auto 26px;font-size:16px}
  .charme-page .gift .cta{background:var(--cream);color:var(--ink);border-color:var(--cream)}
  .charme-page .gift .cta:hover{background:var(--gold);border-color:var(--gold)}
  /* ---- Footer ---- */
  .charme-page .foot-marq{background:var(--gold);border-bottom:2px solid var(--ink);overflow:hidden;white-space:nowrap}
  .charme-page .foot-marq .t{display:inline-block;padding:14px 0;animation:charme-scroll 30s linear infinite}
  .charme-page .foot-marq .t .logo{font-size:30px;margin:0 26px;color:var(--ink)}
  .charme-page .site-foot{background:var(--ink);color:var(--cream);padding:52px 0 30px}
  .charme-page .foot__grid{display:grid;grid-template-columns:1fr;gap:34px}
  @media(min-width:760px){.charme-page .foot__grid{grid-template-columns:1.4fr 1fr 1fr}}
  .charme-page .foot__grid h5{font-family:var(--display);font-weight:800;text-transform:uppercase;letter-spacing:.1em;font-size:12px;color:var(--gold-hi);margin-bottom:14px}
  .charme-page .foot__grid a{display:block;font-size:14px;padding:5px 0;color:#e8e3d9}
  .charme-page .foot__grid a:hover{color:var(--cream)}
  .charme-page .news{display:flex;gap:8px;margin-top:14px;max-width:340px}
  .charme-page .news input{flex:1;border:2px solid var(--cream);background:transparent;color:var(--cream);border-radius:999px;padding:11px 16px;font-family:var(--body);font-size:14px}
  .charme-page .news input::placeholder{color:#cfc9bd}
  .charme-page .news button{background:var(--gold);color:var(--ink);border:2px solid var(--gold);border-radius:999px;font-family:var(--display);font-weight:800;text-transform:uppercase;font-size:13px;padding:0 18px;cursor:pointer}
  .charme-page .foot__legal{max-width:var(--maxw);margin:34px auto 0;padding:20px 20px 0;border-top:1px solid #ffffff22;font-size:12px;color:#b8b2a6;display:flex;flex-wrap:wrap;gap:8px 20px;justify-content:space-between}
  .charme-page .foot__logo{font-size:40px;color:var(--cream);margin-bottom:20px}
  @media(prefers-reduced-motion:reduce){
    .charme-page .marquee__track,.charme-page .foot-marq .t{animation:none}
  }
</style>

<div class="charme-page">

  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <g id="clasp">
        <ellipse cx="20" cy="9" rx="8" ry="8" fill="none" stroke="#C9A227" stroke-width="4"/>
        <rect x="14" y="15" width="12" height="30" rx="6" fill="#C9A227" stroke="#1C1B19" stroke-width="1.5"/>
        <rect x="17.5" y="22" width="5" height="16" rx="2.5" fill="#1C1B19" opacity=".25"/>
      </g>
      <g id="charm">
        <circle cx="60" cy="60" r="52" fill="#C9A227" stroke="#1C1B19" stroke-width="4"/>
        <ellipse cx="60" cy="16" rx="10" ry="10" fill="none" stroke="#1C1B19" stroke-width="4"/>
        <text x="60" y="82" font-family="Archivo,sans-serif" font-weight="900" font-size="58" fill="#1C1B19" text-anchor="middle">é</text>
      </g>
    </defs>
  </svg>

  <div class="announce">{{ section.settings.announce_text }}</div>

  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      <span>ELEVATED LITTLE CHARMS</span><span class="dot">◆</span><span>NOT A PLASTIC TOY</span><span class="dot">◆</span><span>METAL + ENAMEL</span><span class="dot">◆</span><span>SWAP · STACK · GIFT</span><span class="dot">◆</span>
      <span>ELEVATED LITTLE CHARMS</span><span class="dot">◆</span><span>NOT A PLASTIC TOY</span><span class="dot">◆</span><span>METAL + ENAMEL</span><span class="dot">◆</span><span>SWAP · STACK · GIFT</span><span class="dot">◆</span>
    </div>
  </div>

  <div class="site-head">
    <div class="wrap nav">
      <a href="{{ routes.root_url }}" class="logo" aria-label="Charmé home">CHARM<span class="e-wrap">É<svg class="clasp" viewBox="0 0 40 50"><use href="#clasp"/></svg></span></a>
      <nav class="nav__links">
        <a href="#shop">Shop</a>
        <a href="#bundles">Bundles</a>
        <a href="#gift">Gifts</a>
        <a href="#story">Our Story</a>
      </nav>
      <div class="nav__right">
        <a href="{{ routes.cart_url }}" class="bag">Bag · {{ cart.item_count }}</a>
      </div>
    </div>
  </div>

  <section class="hero">
    <div class="wrap" style="padding:0">
      <div class="hero__grid">
        <div class="hero__copy">
          <div class="eyebrow">{{ section.settings.eyebrow }}</div>
          <h1>Your bag,<br>but make it <em>you.</em></h1>
          <p class="sub">Elevated clip-on charms that refresh any bag in seconds — swap them, stack them, gift them.</p>
          <a href="#shop" class="cta">Shop the charm <span class="price">$24.99</span></a>
        </div>
        <div class="hero__vis">
          {%- if section.settings.hero_image != blank -%}
            {{ section.settings.hero_image | image_url: width: 1200 | image_tag: loading: 'eager', class: 'charme-hero-img', style: 'width:100%;height:100%;object-fit:cover;position:absolute;inset:0' }}
          {%- else -%}
            <div class="charm-badge"><svg viewBox="0 0 120 120"><use href="#charm"/></svg></div>
            <div class="slot-note">Image slot · hero-lifestyle 1080×1350</div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <div class="trust">
    <div class="wrap" style="padding:0">
      <div class="trust__grid">
        <div>{{ section.settings.trust_1 }}</div>
        <div><b>Metal + enamel</b> — not plastic</div>
        <div>Arrives <b>gift-ready</b></div>
      </div>
    </div>
  </div>

  <section class="block" id="shop">
    <div class="wrap">
      <div class="kicker">The one everyone's clipping on</div>
      <div class="h2">Meet the charm</div>
      <div class="bundles" id="bundles" style="margin-top:34px">
        <div class="card">
          <div class="card__top"><span class="tag">Bestseller</span><svg class="mini" viewBox="0 0 120 120"><use href="#charm"/></svg></div>
          <div class="card__body">
            <h3>The Charm — Single</h3>
            <span class="save">One clip. A whole new bag.</span>
            <div class="price-row"><span class="now">$24.99</span><span class="was">$39</span></div>
            <a href="{{ routes.all_products_collection_url }}" class="buy">Add to bag</a>
          </div>
        </div>
        <div class="card">
          <div class="card__top"><span class="tag" style="background:var(--gold);color:var(--ink)">Save $11</span><svg class="mini" viewBox="0 0 120 120"><use href="#charm"/></svg></div>
          <div class="card__body">
            <h3>Mix &amp; Match — x2</h3>
            <span class="save">Two moods, one strap</span>
            <div class="price-row"><span class="now">$39</span><span class="was">$50</span></div>
            <a href="{{ routes.all_products_collection_url }}" class="buy">Add to bag</a>
          </div>
        </div>
        <div class="card">
          <div class="card__top"><span class="tag" style="background:var(--persimmon)">Free ship</span><svg class="mini" viewBox="0 0 120 120"><use href="#charm"/></svg></div>
          <div class="card__body">
            <h3>Gift Set — x3</h3>
            <span class="save">Sorted for three people (or you)</span>
            <div class="price-row"><span class="now">$54</span><span class="was">$75</span></div>
            <a href="{{ routes.all_products_collection_url }}" class="buy">Add to bag</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <div class="kicker">How it works</div>
      <div class="h2">Three seconds, done</div>
      <div class="steps">
        <div class="step"><h4>Clip it on</h4><p>Universal lobster clasp fits totes, handbags, backpacks, and keys. No tools, no fuss.</p></div>
        <div class="step"><h4>Change your mood</h4><p>Light enough to swap daily, weighted enough to feel like it belongs on a real bag.</p></div>
        <div class="step"><h4>Show it off</h4><p>Built to photograph. The detail people ask about before they ask where you got it.</p></div>
      </div>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <div class="kicker">Pick a mood · or three</div>
      <div class="h2">The colorways</div>
      <div class="ways">
        <div class="way"><div class="chip" style="background:var(--gold)"></div><span>Goldenhour</span></div>
        <div class="way"><div class="chip" style="background:var(--persimmon)"></div><span>Spritz</span></div>
        <div class="way"><div class="chip" style="background:var(--patina)"></div><span>Patina</span></div>
        <div class="way"><div class="chip" style="background:var(--ink)"></div><span>Noir</span></div>
        <div class="way"><div class="chip" style="background:var(--cream);"></div><span>Crème</span></div>
      </div>
    </div>
  </section>

  <div class="look">
    <div class="wrap" style="padding:0">
      <div class="look__grid">
        <div class="look__vis">
          {%- if section.settings.lookbook_image != blank -%}
            {{ section.settings.lookbook_image | image_url: width: 1200 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;position:absolute;inset:0' }}
          {%- else -%}
            <div class="charm-badge" style="box-shadow:10px 10px 0 var(--cream)"><svg viewBox="0 0 120 120"><use href="#charm"/></svg></div>
            <div class="slot-note">Image slot · lookbook 1080×1350</div>
          {%- endif -%}
        </div>
        <div class="look__copy">
          <div class="kicker" style="color:var(--gold-hi)">The lookbook</div>
          <div class="h2">Not a toy.<br>A statement.</div>
          <p class="quote">"A $300 bag shouldn't need replacing to feel new. One clip-on charm, endless moods."</p>
          <div class="attr">— Charmé, est. 2026</div>
        </div>
      </div>
    </div>
  </div>

  <section class="block" id="story">
    <div class="wrap">
      <div class="kicker">What buyers say</div>
      <div class="h2">Verified &amp; obsessed</div>
      <div class="reviews">
        <div class="review"><div class="stars">★★★★★</div><p>"Way heavier and nicer than I expected — looks like it cost triple. Everyone at brunch asked."</p><div class="who">★ Verified buyer</div></div>
        <div class="review"><div class="stars">★★★★★</div><p>"Bought one, came back for the gift set. The little box makes it feel expensive."</p><div class="who">★ Verified buyer</div></div>
        <div class="review"><div class="stars">★★★★★</div><p>"Clips on solid, hasn't scratched my bag, and it actually photographs. Rare."</p><div class="who">★ Verified buyer</div></div>
      </div>
      <p style="font-size:12px;color:#8a857d;margin-top:16px">Sample reviews shown — replace with real Judge.me reviews before launch (FTC).</p>
    </div>
  </section>

  <div class="gift" id="gift">
    <div class="wrap" style="padding:0">
      <div class="inner">
        <div class="h2">The easy "just because."</div>
        <p>Under $30, arrives gift-ready in a clean little box, and she'll actually use it. Sorted for birthdays, stocking-stuffers, and secret santa.</p>
        <a href="#shop" class="cta">Shop gift sets</a>
      </div>
    </div>
  </div>

  <div class="foot-marq" aria-hidden="true">
    <div class="t">
      <span class="logo">CHARMÉ</span><span class="logo">CHARMÉ</span><span class="logo">CHARMÉ</span><span class="logo">CHARMÉ</span>
      <span class="logo">CHARMÉ</span><span class="logo">CHARMÉ</span><span class="logo">CHARMÉ</span><span class="logo">CHARMÉ</span>
    </div>
  </div>

  <div class="site-foot">
    <div class="wrap">
      <div class="foot__logo logo">CHARM<span class="e-wrap">É<svg class="clasp" viewBox="0 0 40 50"><use href="#clasp"/></svg></span></div>
      <div class="foot__grid">
        <div>
          <h5>Stick with your new bestie</h5>
          <p style="font-size:14px;color:#cfc9bd;max-width:36ch">{{ section.settings.footer_blurb }}</p>
          {% form 'customer' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="news">
              <input type="email" name="contact[email]" placeholder="Email for 10% off" aria-label="Email address" required>
              <button type="submit">Join</button>
            </div>
          {% endform %}
        </div>
        <div>
          <h5>Shop</h5>
          <a href="{{ routes.all_products_collection_url }}">The Charm</a>
          <a href="#bundles">Bundles</a>
          <a href="#gift">Gift Sets</a>
          <a href="#shop">Colorways</a>
        </div>
        <div>
          <h5>Help</h5>
          <a href="/pages/shipping-returns">Shipping &amp; Returns</a>
          <a href="/policies/refund-policy">Refund Policy</a>
          <a href="/policies/privacy-policy">Privacy Policy</a>
          <a href="/policies/terms-of-service">Terms of Service</a>
          <a href="/pages/contact">Contact</a>
        </div>
      </div>
      <div class="foot__legal">
        <span>© {{ 'now' | date: '%Y' }} Charmé. All rights reserved.</span>
        <span>Made for the bag you already love.</span>
      </div>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Charmé Home",
  "settings": [
    {
      "type": "text",
      "id": "announce_text",
      "label": "Announcement bar",
      "default": "Free US shipping over $35 · Ships in 8–15 days"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Hero eyebrow",
      "default": "The it-girl bag charm · $24.99"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust item 1",
      "default": "Ships in 8–15 days, tracked"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (replaces the placeholder badge)"
    },
    {
      "type": "image_picker",
      "id": "lookbook_image",
      "label": "Lookbook image"
    },
    {
      "type": "textarea",
      "id": "footer_blurb",
      "label": "Footer blurb",
      "default": "Elevated clip-on charms, shipped fast from a small studio. Delivery to the US: typically 8–15 days, tracked."
    }
  ],
  "presets": [
    { "name": "Charmé Home" }
  ]
}
