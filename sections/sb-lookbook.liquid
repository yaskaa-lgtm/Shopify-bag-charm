{{ 'sb-sections.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} { --sb-cols: {{ section.settings.columns_desktop }}; }
</style>

<div class="sb-lookbook page-width">
  {%- if section.settings.heading != blank -%}
    <h2 class="sb-h2 sb-lookbook__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="sb-lookbook__grid">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="sb-look"
        {{ block.shopify_attributes }}
      >
        <div class="sb-look__media">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1400 | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 990px) 33vw, 100vw',
              widths: '400, 600, 900, 1200, 1400',
              class: 'sb-look__img'
            }}
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'sb-look__img placeholder' }}
          {%- endif -%}
          <div class="sb-look__overlay">
            {%- if block.settings.title != blank -%}
              <h3 class="sb-look__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <p class="sb-look__caption">{{ block.settings.caption }}</p>
            {%- endif -%}
          </div>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "SB Lookbook",
  "tag": "section",
  "class": "sb-section sb-section--lookbook",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Lookbooks"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on desktop",
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "City Girl"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "From brunch to backseat — the bags that keep up with her."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SB Lookbook",
      "blocks": [
        { "type": "look" },
        { "type": "look", "settings": { "title": "The Viral Pouches", "caption": "Every colour, every stripe — the pouch your feed keeps showing you." } },
        { "type": "look", "settings": { "title": "It Girl Approved", "caption": "The accessories the it girls can't put down." } }
      ]
    }
  ]
}
{% endschema %}
